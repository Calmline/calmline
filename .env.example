# =============================================================================
# Calmline — copy to `.env.local` for local dev.
# For Vercel: Project → Settings → Environment Variables
# Enable the SAME keys for Production AND Preview (and Development if you use it).
# =============================================================================

# --- OpenAI ---
OPENAI_API_KEY=your_key_here

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=your_url_here
SUPABASE_SERVICE_ROLE_KEY=your_key_here

# --- Public app URL (gateway callbacks, links) ---
CALMLINE_APP_URL=https://your-vercel-url.vercel.app

# --- Live Session UI → realtime-gateway (browser must reach this; use wss:// in prod) ---
NEXT_PUBLIC_GATEWAY_WS=wss://your-ngrok-or-gateway-url

# --- Twilio / stream base (often wss:// for Media Streams; match your Twilio config) ---
TWILIO_WS_BASE_URL=https://your-base-url

# =============================================================================
# Local-only: custom Node server (server.js) — not used by default Vercel Next.js
# REALTIME_GATEWAY_WS_URL=ws://127.0.0.1:8787
# =============================================================================
# Separate deploy: realtime-gateway/.env (Deepgram, PORT, etc.)
# =============================================================================
