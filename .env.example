# OpenAI (required for analysis)
OPENAI_API_KEY=sk-...

# Supabase (required for storage)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Twilio Voice (live call stream)
# Live Session UI connects to realtime-gateway WebSocket. Set in production to your gateway URL.
# NEXT_PUBLIC_GATEWAY_WS=ws://localhost:8787/ui   # optional; fallback for local dev
# TWILIO_WS_BASE_URL=wss://your-domain.com    # for TwiML Media Stream in production

# Policy RAG: realtime-gateway calls Next.js to retrieve policy chunks before coaching
# CALMLINE_APP_URL=http://localhost:3000   # optional; default for local dev
